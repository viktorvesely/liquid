{
    "name": "protein",
    "verbose": 1,
    "epoch": 300,
    "batch_size": 1024,
    "n_input": 9,
    "n_output": 1,
    "LongLiquid": {
        "lr": 0.004,
        "architecture": {
            "n_citizens": 6,
            "layers_body": 1,
            "layers_y": 3,
            "layers_d": 3,
            "width_body": 350,
            "width_y": 350,
            "width_d": 50,
            "dropout_body": 0.0,
            "dropout_y": 0.0,
            "dropout_d": 0.0,
            "le_kwargs": {
                "load_distribution_lambda": 0.7,
                "specialization_lambda": 0.1,
                "solver": "sink_many"
            }
        }
    },
    "LongMoe": {
        "lr": 0.002,
        "architecture": {
            "layers_body": 6,
            "width_body": 200,
            "n_citizens": 30,
            "layers_router": 5,
            "width_router": 800,
            "body_dropout": 0.0,
            "router_dropout": 0.01,
            "moe_kwargs": {
                "load_distribution_lambda": 1,
                "specialization_lambda": 0.92
            }
        }
    },
    "rf": {
        "n_estimators": 150,
        "max_depth": null,
        "min_samples_split": 2,
        "min_samples_leaf": 4,
        "max_features": 1.0,
        "max_leaf_nodes": null
    },
    "lgbm": {
        "learning_rate": 0.2,
        "n_estimators": 800,
        "max_depth": null,
        "num_leaves": 100,
        "subsample": 0.96,
        "lambda_l2" : 0.2,
        "feature_fraction": 1.0,
        "boosting": "gbdt",
        "min_data_in_leaf": 20
    }
}