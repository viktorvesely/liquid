            "n_fc_moe_blocks": 2,
            "max_pool_every": 2,
            "moe_fc_kwargs": {
                "width": 100,
                "dropout": 0.2
            },
            "moe_kwargs": {
                "load_distribution_lambda": 0.0,
                "specialization_lambda": 0.0
            },
            "router_cnn_kwargs": {},
            "router_fc_kwargs": {
                "width": 50,
                "dropout": 0.2
            }
        }
    },
    "SimpleNN": {
        "lr": 0.001,
        "architecture": {
            "last_channels": 400,
            "n_cnn_layers": 8,
            "n_fc_layers": 4,
            "max_pool_every": 2,
            "fc_kwargs": {
                "width": 200,
                "dropout": 0.2
            }
