{
    "name": "cifar10",
    "epoch": 10,
    "batch_size": 256,
    "n_input": 3,
    "n_output": 10,
    "LongLiquid": {
        "lr": 0.001,
        "architecture": {
            "last_channels": 40,
            "n_citizens": 10,
            "layers_body": 3,
            "layers_y": 3,
            "layers_d": 1,
            "le_kwargs": {
                "load_distribution_lambda": 0.3,
                "specialization_lambda": 0.3,
                "solver": "sink_many"
            }
        }
    },
    "BlockLiquid": {
        "lr": 0.001,
        "architecture": {
            "last_channels": 40,
            "n_citizens": 10,
            "layers_body": 1,
            "layers_y": 1,
            "layers_d": 1,
            "n_le_blocks": 6,
            "le_kwargs": {
                "load_distribution_lambda": 0.3,
                "specialization_lambda": 0.3,
                "solver": "sink_many"
            }
        }
    },
    "Moe": {
        "lr": 0.001,
        "architecture": {
            "last_channels": 40,
            "n_citizens": 10,
            "n_moe_blocks": 4,
            "layers_in_moe_blocks": 2,
            "layers_router": 1,
            "moe_kwargs": {
                "load_distribution_lambda": 0.3,
                "specialization_lambda": 0.3
            }
        }
    }
}