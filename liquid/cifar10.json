{
    "name": "cifar10",
    "verbose": 1,
    "epoch": 50,
    "batch_size": 720,
    "n_input": 3,
    "n_output": 10,
    "LongLiquid": {
        "lr": 0.001,
        "architecture": {
            "n_citizens": 10,
            "last_channels": 50,
            "le_cnn_kwargs": {
                "layers_y": 3,
                "layers_d": 2,
                "layers_body": 5,
                "max_pool_every": 2
            },
            "le_fc_kwargs": {
                "layers_y": 2,
                "layers_body": 2,
                "layers_d": 1,
                "width_body": 100,
                "width_y": 100,
                "width_d": 50,
                "dropout_body": 0.2,
                "dropout_y": 0.2,
                "dropout_d": 0.2
            },
            "le_kwargs": {
                "load_distribution_lambda": 0.2,
                "specialization_lambda": 0.15,
                "solver": "sink_many"
            }
        }
    },
    "BlockLiquid": {
        "lr": 0.001,
        "architecture": {
            "n_citizens": 15,
            "last_channels": 50,
