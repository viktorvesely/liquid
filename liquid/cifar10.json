            "le_cnn_kwargs": {},
            "le_fc_kwargs": {
                "width_body": 100,
                "width_y": 100,
                "width_d": 50,
                "dropout_body": 0.2,
                "dropout_y": 0.2,
                "dropout_d": 0.2
            },
            "le_kwargs": {
                "load_distribution_lambda": 0.2,
                "specialization_lambda": 0.15,
                "solver": "sink_many"
            }
        }
    },
    "LongMoe": {
        "lr": 0.001,
        "architecture": {
            "last_channels": 50,
            "n_citizens": 10,
            "moe_cnn_kwargs": {
                "max_pool_every": 2,
                "layers": 6
            },
            "moe_fc_kwargs": {
                "layers": 3,
                "width": 100,
                "dropout": 0.2
            },
            "router_cnn_kwargs": {
                "layers": 2
            },
            "router_fc_kwargs": {
                "layers": 2,
                "dropout": 0.2,
                "width": 50
            },
            "moe_kwargs": {
                "load_distribution_lambda": 0.0,
                "specialization_lambda": 0.0
            }
        }
    },
    "BlockMoe": {
        "lr": 0.001,
        "architecture": {
            "n_citizens": 10,
            "last_channels": 50,
